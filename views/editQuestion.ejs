<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Edit Question - AptiHub</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="admin-bg">
  <div class="container mt-5 mb-5">
    <h2 class="text-center text-light fw-bold mb-4">Edit Question</h2>

    <form action="/admin/edit-question/<%= q._id %>" method="POST" class="p-4 rounded shadow-lg bg-dark text-light" style="max-width: 700px; margin: auto;">
      <div class="mb-3">
        <label class="form-label">Topic</label>
        <input type="text" class="form-control" name="topic" value="<%= q.topic %>" required>
      </div>

      <div class="mb-3">
        <label class="form-label">Difficulty</label>
        <select class="form-select" name="difficulty" required>
          <option value="Easy" <%= q.difficulty==='Easy'?'selected':'' %>>Easy</option>
          <option value="Medium" <%= q.difficulty==='Medium'?'selected':'' %>>Medium</option>
          <option value="Hard" <%= q.difficulty==='Hard'?'selected':'' %>>Hard</option>
        </select>
      </div>

      <div class="mb-3">
        <label class="form-label">Question</label>
        <textarea class="form-control" name="question" rows="3" required><%= q.question %></textarea>
      </div>

      <div class="row">
        <div class="col-md-6 mb-3">
          <label class="form-label">Option A</label>
          <input type="text" class="form-control" name="optionA" value="<%= q.options.A %>" required>
        </div>
        <div class="col-md-6 mb-3">
          <label class="form-label">Option B</label>
          <input type="text" class="form-control" name="optionB" value="<%= q.options.B %>" required>
        </div>
      </div>

      <div class="row">
        <div class="col-md-6 mb-3">
          <label class="form-label">Option C</label>
          <input type="text" class="form-control" name="optionC" value="<%= q.options.C %>" required>
        </div>
        <div class="col-md-6 mb-3">
          <label class="form-label">Option D</label>
          <input type="text" class="form-control" name="optionD" value="<%= q.options.D %>" required>
        </div>
      </div>

      <div class="row">
        <div class="col-md-6 mb-3">
          <label class="form-label">Correct Answer</label>
          <select class="form-select" name="correctAnswer" required>
            <option value="A" <%= q.correctAnswer==='A'?'selected':'' %>>A</option>
            <option value="B" <%= q.correctAnswer==='B'?'selected':'' %>>B</option>
            <option value="C" <%= q.correctAnswer==='C'?'selected':'' %>>C</option>
            <option value="D" <%= q.correctAnswer==='D'?'selected':'' %>>D</option>
          </select>
        </div>

        <div class="col-md-6 mb-3">
          <label class="form-label">Marks</label>
          <input type="number" class="form-control" name="marks" value="<%= q.marks %>" min="1" required>
        </div>
      </div>

      <div class="text-center mt-4">
        <button type="submit" class="btn btn-primary px-4 me-3">Update Question</button>
        <a href="/admin/view-questions" class="btn btn-outline-light px-4">Cancel</a>
      </div>
    </form>
  </div>
</body>
</html>

