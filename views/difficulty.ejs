<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Select Difficulty</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="container mt-5 text-center">
    <h1>Select Difficulty for <%= topic %></h1>

    <div class="d-grid gap-3 col-6 mx-auto mt-4">
      <a href="/quiz/<%= topic %>/Easy" class="btn btn-primary btn-lg">Easy</a>
      <a href="/quiz/<%= topic %>/Medium" class="btn btn-warning btn-lg">Medium</a>
      <a href="/quiz/<%= topic %>/Hard" class="btn btn-danger btn-lg">Hard</a>
    </div>

    <a href="/topics" class="d-block mt-4">Back to Topics</a>
  </div>
</body>
</html>

